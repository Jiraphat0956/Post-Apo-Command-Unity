  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The Story\n\"Five years after the nuclear cataclysm, radioactive dust
    has turned once-thriving cities into rusted graveyards. Skills from the old world
    are now your only weapons for survival. You are the Leader of a survivor group
    that has just intercepted a faint radio signal: 'A rescue team is waiting at
    the final extraction point.' You must lead your people through the ruins and
    manage your dwindling resources to reach the destination before the last light
    of hope fades forever.\"\n\nHow to Play\n1. Form Your Team (1-3 Survivors)\n\n-
    You can send between 1 to 3 survivors on each expedition.\n\n- High Manpower:
    More members increase your total stats and success chance, but consume more Supplies.\n\n-
    Low Manpower: Fewer members save food but significantly increase the risk to
    the team.\n\n2. Stat Match (Assemble by Expertise)\n\n- Check the area's requirements
    (Str, Per, Agi) and assign survivors with the right Jobs to maximize your Success
    Chance.\n\n3. Fatigue & Risk\n\n- Every mission increases Fatigue. Exhausted
    survivors will drastically lower the entire team\u2019s Success Chance.\n\nWarning:
    If the Success Chance is too low, your team may suffer severe injuries or go
    missing during the mission.\n\n4. The Detour (Skipping Expeditions)\n\nIf the
    path ahead looks too suicidal, you may choose to Skip (Take a Detour).\n\nCaution:
    A detour takes the same amount of time but costs massive Supplies due to the
    longer distance traveled without scavenging for new resources."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8c44c4ffb6766164c9d2a56623df7d68, type: 2}
  m_sharedMaterial: {fileID: 8677409307513598230, guid: 8c44c4ffb6766164c9d2a56623df7d68, type: 2}
